# Minimal local env reference for cai-platform-v2
# This file documents the current runtime surface.
# Commands do not auto-load it.

# Deterministic platform boundary
PLATFORM_API_BASE_URL=http://127.0.0.1:8000

# CAI-facing integration compatibility for the host-run orchestrator/terminal
# These variables matter only if you install the optional CAI extra and use
# `python3 -m cai_orchestrator run-cai-terminal`.
# We preserve the CAI_AGENT_TYPE and CAI_MODEL names for operator ergonomics,
# but only the new platform agent is supported here.
CAI_AGENT_TYPE=platform_investigation_agent

# Optional: model name passed through to the external CAI SDK when used.
# CAI_MODEL=<model-name>
